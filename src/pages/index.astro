---
import Layout from '../layouts/Layout.astro';
import { bands } from '../data/bands.js';
---

<Layout title="Opinionated Translations" description="Japanese song translations">
  <h1>Opinionated Translations</h1>
  <p style={{ color: '#666', marginBottom: '2rem' }}>
    Opinionated translations of Japanese song lyrics. Click a band below to explore.
  </p>
  <div style={{ display: 'flex', flexDirection: 'column', gap: '1rem' }}>
    {bands.map((band) => (
      <a href={`${import.meta.env.BASE_URL}/bands/${band.id}`} style={{ padding: '1rem', border: '1px solid #e5e5e5', borderRadius: '8px' }}>
        <strong>{band.name}</strong>
        <span style={{ color: '#999', marginLeft: '0.5rem' }}>({band.albums.length} album{band.albums.length !== 1 ? 's' : ''})</span>
      </a>
    ))}
  </div>
</Layout>
