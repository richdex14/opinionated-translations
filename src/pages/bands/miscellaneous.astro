---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { bands } from '../../data/bands.js';

const band = bands.find((b) => b.id === 'miscellaneous');
const songs = await getCollection('songs', ({ data }) => data.band === 'miscellaneous' && (!import.meta.env.PROD || !data.draft));
songs.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title={band.name}>
  <h1>{band.name}</h1>
  <p style={{ color: '#666', marginBottom: '2rem' }}>Assorted song translations</p>
  {songs.length === 0 ? (
    <p style={{ color: '#999' }}>No translations yet.</p>
  ) : (
    <div style={{ display: 'flex', flexDirection: 'column', gap: '1rem' }}>
      {songs.map((song) => (
        <a href={`${import.meta.env.BASE_URL}/songs/${song.id}/`} style={{ padding: '1rem', border: '1px solid #e5e5e5', borderRadius: '8px' }}>
          <strong>{song.data.title}</strong>
          {song.data.album && <span style={{ color: '#666', marginLeft: '0.5rem' }}>({song.data.album})</span>}
        </a>
      ))}
    </div>
  )}
</Layout>
