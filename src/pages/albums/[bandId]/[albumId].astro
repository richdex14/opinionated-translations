---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { bands } from '../../../data/bands.js';

export async function getStaticPaths() {
  const paths = [];
  for (const band of bands) {
    for (const album of band.albums) {
      paths.push({ params: { bandId: band.id, albumId: album.id } });
    }
  }
  return paths;
}

const bandId = Astro.params.bandId;
const albumId = Astro.params.albumId;

const band = bands.find((b) => b.id === bandId);
const album = band?.albums.find((a) => a.id === albumId);

if (!band || !album) {
  return Astro.response.redirect(`${import.meta.env.BASE_URL}`);
}

const songs = await getCollection('songs', ({ data }) => data.band === bandId && data.album === albumId && (!import.meta.env.PROD || !data.draft));
songs.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title={`${album.name} - ${band.name}`}>
  <div style={{ marginBottom: '2rem' }}>
    <a href={`${import.meta.env.BASE_URL}/bands/${bandId}`} style={{ fontSize: '0.875rem', color: '#666' }}>← Back to {band.name}</a>
  </div>
  <h1>{album.name}</h1>
  <p style={{ color: '#666', marginBottom: '2rem' }}>{band.name} ({album.year})</p>
  {songs.length === 0 ? (
    <p style={{ color: '#999' }}>No translations yet.</p>
  ) : (
    <div style={{ display: 'flex', flexDirection: 'column', gap: '1rem' }}>
      {songs.map((song) => (
        <a href={`${import.meta.env.BASE_URL}/songs/${song.id}/`} style={{ padding: '1rem', border: '1px solid #e5e5e5', borderRadius: '8px' }}>
          <strong>{song.data.title}</strong>
          {song.data.description && <p style={{ color: '#666', marginTop: '0.5rem', fontSize: '0.875rem' }}>{song.data.description}</p>}
        </a>
      ))}
    </div>
  )}
</Layout>
